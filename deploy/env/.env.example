COMPOSE_PROJECT_NAME=agritrace-prod

# Core app secrets
JWT_ACCESS_SECRET=replace_with_long_random_value
TRACE_SIGNING_PRIVATE_KEY_PEM=replace_with_private_key_pem
TRACE_SIGNING_PUBLIC_KEY_PEM=replace_with_public_key_pem
WHISPER_API_KEY=
PLANTNET_API_KEY=
WHISPER_API_URL=
OPENFOODFACTS_BASE=https://world.openfoodfacts.org/api/v0

# PostgreSQL
POSTGRES_DB=agritrace
POSTGRES_USER=agritrace
POSTGRES_PASSWORD=replace_with_secure_password

# MinIO
MINIO_ROOT_USER=agritrace
MINIO_ROOT_PASSWORD=replace_with_secure_password
MINIO_BUCKET=agrotrace-media
MINIO_BIND_ADDRESS=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Ingress and monitoring
NGINX_HTTP_PORT=80
PROMETHEUS_BIND_ADDRESS=127.0.0.1
PROMETHEUS_PORT=9090
GRAFANA_BIND_ADDRESS=127.0.0.1
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_with_secure_password
