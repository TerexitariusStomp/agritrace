{
  "id": null,
  "uid": "agritrace-api-overview",
  "title": "AgroTrace API Overview",
  "tags": [
    "agritrace",
    "production"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Healthy Scrape Targets",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(up)",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Container CPU Usage (cores)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (container_label_com_docker_compose_service) (rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service!=""}[5m]))",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Container Memory Usage (MB)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (container_label_com_docker_compose_service) (container_memory_usage_bytes{container_label_com_docker_compose_service!=""}) / 1024 / 1024",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Redis Connected Clients",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "redis",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "PostgreSQL Connections",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(pg_stat_database_numbackends)",
          "legendFormat": "postgres",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    }
  ]
}
