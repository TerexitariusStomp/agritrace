{
  "name": "agrotrace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend",
    "mobile",
    "shared",
    "web-admin",
    "web-trace",
    "pwa"
  ],
  "scripts": {
    "bootstrap": "npm install --workspaces",
    "dev:backend": "npm --workspace backend run dev",
    "start:backend": "npm --workspace backend start",
    "dev:mobile": "npm --workspace mobile run start",
    "dev:web-admin": "npm --workspace web-admin run start",
    "dev:web-trace": "npm --workspace web-trace run start",
    "dev:pwa": "npm --workspace pwa run start",
    "build": "npm -ws run build",
    "lint": "npm -ws run lint || echo 'lint not configured'",
    "format": "npm -ws run format || echo 'format not configured'"
  }
}

