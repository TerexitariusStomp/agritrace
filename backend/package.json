{
  "name": "agrotrace-backend",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/jobs/worker.ts --run",
    "start": "node dist/index.js",
    "start:worker": "node dist/jobs/worker.js --run",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/multipart": "^8.3.0",
    "@types/jsonwebtoken": "^9.0.10",
    "argon2": "^0.44.0",
    "better-sqlite3": "^9.4.0",
    "drizzle-orm": "^0.44.2",
    "fastify": "^4.29.1",
    "geolib": "^3.3.4",
    "jsonwebtoken": "^9.0.3",
    "minio": "^8.0.6",
    "postgres": "^3.4.7",
    "qrcode": "^1.5.3",
    "redis": "^4.7.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.30",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
